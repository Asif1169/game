# Copy this file to .env.local and fill in real values.
# All NEXT_PUBLIC_* vars are exposed to the browser; never put secrets there.

# ---- WalletConnect v2 - from https://cloud.walletconnect.com ----
# Enables QR-code / multi-wallet connections.
NEXT_PUBLIC_WC_PROJECT_ID=

# ---- Your app's public URL ----
# Use http://localhost:3000 for dev; https://your-app.vercel.app after deploy
NEXT_PUBLIC_URL=http://localhost:3000

# ---- RPC URL (public Base RPC with CORS support) ----
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# ---- Upstash Redis (for leaderboard persistence on serverless) ----
REDIS_URL=
REDIS_TOKEN=

# ---- Game config ----
# Deployed ScoreSubmission contract address (set after deploying via Remix)
NEXT_PUBLIC_CONTRACT_ADDRESS=
# Fee recipient (owner wallet that receives fees) - set at deploy time
NEXT_PUBLIC_PAYMENT_RECIPIENT=0x7d9Cb2994D86B6a4e65761B5d81DADa69ce54a7f
NEXT_PUBLIC_PAYMENT_AMOUNT=0.0001
