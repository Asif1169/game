# Copy this file to .env.local and fill in real values.
# All NEXT_PUBLIC_* vars are exposed to the browser; never put secrets there.

# ---- CDP - from https://portal.cdp.coinbase.com (REQUIRED) ----
NEXT_PUBLIC_CDP_PROJECT_ID=your_cdp_project_id

# ---- Your app's public URL ----
# Use http://localhost:3000 for dev; https://your-app.vercel.app after deploy
NEXT_PUBLIC_URL=http://localhost:3000

# ---- Farcaster account association ----
# Generated AFTER deploy via https://build.base.org/account-association
# (sign with your Farcaster custody wallet, NOT regular MetaMask)
NEXT_PUBLIC_FARCASTER_HEADER=
NEXT_PUBLIC_FARCASTER_PAYLOAD=
NEXT_PUBLIC_FARCASTER_SIGNATURE=

# ---- Upstash Redis (for webhooks & notifications) ----
REDIS_URL=
REDIS_TOKEN=

# ---- Optional: Neynar (Farcaster user lookup) ----
NEYNAR_API_KEY=

# ---- Game config ----
# Deployed ScoreSubmission contract address (set after deploying via Remix)
NEXT_PUBLIC_CONTRACT_ADDRESS=
# Fee recipient (owner wallet that receives fees) - set at deploy time
NEXT_PUBLIC_PAYMENT_RECIPIENT=0x7d9Cb2994D86B6a4e65761B5d81DADa69ce54a7f
NEXT_PUBLIC_PAYMENT_AMOUNT=0.0001
